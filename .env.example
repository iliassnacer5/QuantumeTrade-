# ============================================================
#  QUANTUM TRADE AI — Variables d'environnement (exemple)
#  Copier en `.env` et renseigner. NE JAMAIS committer `.env`.
# ============================================================

# ---- Environnement ----
ENVIRONMENT=dev                # dev | staging | prod
LOG_LEVEL=INFO

# ---- Backend / API ----
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# ---- Persistance ----
# true  = repositories en mémoire (dev rapide, sans DB)
# false = PostgreSQL (le docker-compose force déjà false pour le backend)
USE_IN_MEMORY_DB=true

# ---- Base de données (PostgreSQL + TimescaleDB) ----
POSTGRES_USER=quantum
POSTGRES_PASSWORD=quantum_dev_pwd
POSTGRES_DB=quantum
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://quantum:quantum_dev_pwd@postgres:5432/quantum

# ---- Redis (cache + pub/sub) ----
REDIS_URL=redis://redis:6379/0

# ---- Kafka / Redpanda (pipeline data) ----
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# ---- LLM (via LiteLLM) ----
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LITELLM_DEFAULT_MODEL=gemini/gemini-2.5-pro

# ---- Données marché (MVP: crypto) ----
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- News / sentiment ----
FINNHUB_API_KEY=
NEWSAPI_KEY=

# ---- Facturation ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=

# ---- Alertes ----
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=                # ou SENDGRID_API_KEY
EMAIL_FROM=alerts@quantumtrade.ai

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
